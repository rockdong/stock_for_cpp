/* pages/mine/mine.wxss */

.container {
  padding: var(--spacing-lg);
  padding-bottom: 100rpx;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  background-color: var(--bg-white);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.user-avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background-color: var(--bg-gray);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
}

.avatar-placeholder {
  font-size: 32px;
}

.user-avatar-img {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  margin-right: var(--spacing-md);
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 18px;
  font-weight: bold;
}

.user-desc {
  font-size: 12px;
  color: var(--text-tertiary);
  margin-top: 4px;
}

/* 菜单列表 */
.menu-list {
  background-color: var(--bg-white);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-lg);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
  border-bottom: 1px solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: var(--bg-gray);
}

.menu-icon {
  width: 24px;
  text-align: center;
  margin-right: var(--spacing-md);
}

.menu-text {
  flex: 1;
  font-size: 16px;
}

.menu-arrow {
  color: var(--text-tertiary);
  font-size: 18px;
}

/* 版本信息 */
.version {
  text-align: center;
  color: var(--text-tertiary);
  font-size: 12px;
  margin-top: var(--spacing-xl);
}