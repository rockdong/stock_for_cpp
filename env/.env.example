# ============================================
# Stock Analysis System - 环境变量配置模板
# ============================================
# 使用方法：复制此文件为 .env 并填写实际值
# cp env/.env.example .env
# ============================================

# ============================================
# 应用配置
# ============================================
APP_NAME=Stock Analysis System
APP_ENV=production
DEBUG_MODE=false

# ============================================
# 日志配置
# ============================================
# 日志级别: TRACE, DEBUG, INFO, WARN, ERROR, CRITICAL, OFF
LOG_LEVEL=INFO
LOG_PATTERN=[%Y-%m-%d %H:%M:%S.%e] [%^%l%$] [%t] %v
LOG_FILE_PATH=logs/app.log
LOG_CONSOLE_ENABLED=true
LOG_FILE_ENABLED=true
LOG_MAX_FILE_SIZE=10485760
LOG_MAX_FILES=3
LOG_ASYNC_ENABLED=false
LOG_ASYNC_QUEUE_SIZE=8192

# ============================================
# 数据源配置 (Tushare Pro API)
# ============================================
DATA_SOURCE_URL=http://api.tushare.pro
DATA_SOURCE_API_KEY=your_tushare_token_here
DATA_SOURCE_TIMEOUT=30
DATA_SOURCE_RETRY_TIMES=3
DATA_SOURCE_RETRY_DELAY=1000

# Tushare API 限流配置
TUSHARE_RATE_LIMIT=8
TUSHARE_BURST_SIZE=10

# ============================================
# 策略配置
# ============================================
# 可选策略（分号分隔）：
# EMA25_GREATER_17_PRICE_MATCH;EMA17TO25;EMA17_BREAKOUT;EMA25_CROSSOVER 等
STRATEGIES=EMA25_GREATER_17_PRICE_MATCH

# ============================================
# 调度配置
# ============================================
# 每日分析执行时间 (HH:MM)
SCHEDULER_EXECUTE_TIME=20:00

# 分析日期切换时间 (HH:MM)
# 当前时间 < 切换时间时，分析日期为昨天
# 当前时间 >= 切换时间时，分析日期为今天
ANALYSIS_DATE_SWITCH_TIME=02:00

# ============================================
# 飞书机器人配置
# ============================================
# 应用 ID（从飞书开放平台获取）
FEISHU_APP_ID=your_app_id_here
# 应用密钥
FEISHU_APP_SECRET=your_app_secret_here
# 事件订阅验证令牌
FEISHU_VERIFICATION_TOKEN=your_verification_token_here

# ============================================
# 服务配置
# ============================================
# 服务端口
PORT=3000
# Node.js 环境
NODE_ENV=production

# ============================================
# 数据库配置
# ============================================
# SQLite 数据库路径（绝对路径或相对于工作目录）
DB_PATH=/app/stock.db

# MySQL 数据库配置（可选，优先使用 MySQL）
DB_TYPE=mysql
DB_HOST=mysql
DB_PORT=3306
DB_NAME=stock_db
DB_USER=stock_user
DB_PASSWORD=stock_password
DB_POOL_SIZE=10
DB_TIMEOUT=30
DB_CHARSET=utf8mb4

# ============================================
# 基本面筛选配置
# ============================================
# 估值阈值
FUNDAMENTAL_PE_MAX=30
FUNDAMENTAL_PB_MAX=5
FUNDAMENTAL_PEG_MAX=1.5

# 盈利能力阈值
FUNDAMENTAL_ROE_MIN=10
FUNDAMENTAL_GROSS_MARGIN_MIN=20
FUNDAMENTAL_NET_MARGIN_MIN=10

# 增长能力阈值
FUNDAMENTAL_REVENUE_GROWTH_MIN=5
FUNDAMENTAL_PROFIT_GROWTH_MIN=5

# 财务健康阈值
FUNDAMENTAL_DEBT_RATIO_MAX=60
FUNDAMENTAL_CURRENT_RATIO_MIN=1

# 总分阈值
FUNDAMENTAL_TOTAL_SCORE_MIN=60

# ============================================
# Web API 配置
# ============================================
# Web API 请求超时时间（毫秒）
WEB_API_TIMEOUT=30000
# 基本面筛选超时时间（毫秒）
FUNDAMENTAL_FILTER_TIMEOUT=60000

# ============================================
# 自适应学习配置
# ============================================
# 是否启用自适应学习
ADAPTIVE_LEARNING_ENABLED=false
# 预测历史记录文件路径
PREDICTION_HISTORY_PATH=data/signal_predictions.json
# 准确率阈值（低于此值触发优化）
OPTIMIZATION_THRESHOLD=0.70
# 最少预测次数（用于统计分析）
MIN_PREDICTIONS_FOR_ANALYSIS=10

# ============================================
# 微信公众号配置
# ============================================
WECHAT_APP_ID=wxxxxxxxxxxx
WECHAT_APP_SECRET=xxxxxxxxxxxxxxxx
WECHAT_TOKEN=your_token

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d